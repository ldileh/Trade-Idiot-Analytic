{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trade-Idiot-Analytic",
  "version": "1.0.0",
  "identifier": "com.tradeidiot.analytic",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Trade-Idiot-Analytic",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"],
    "externalBin": ["bin/backend"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ldileh/Trade-Idiot-Analytic/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMjdCQzZBQTNCMjFGNTIKUldSU0g3S2phcnduWHdXeEY3aEd4YUxqODNrSzM5VGFBOXJ5K0lJbEg5aXY0QzhabDd6Zk9BSzMK"
    }
  }
}
