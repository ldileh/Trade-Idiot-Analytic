{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trade-Idiot-Analytic",
  "version": "0.1.0",
  "identifier": "com.tradeidiot.analytic",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Trade-Idiot-Analytic",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/backend"]
  }
}
